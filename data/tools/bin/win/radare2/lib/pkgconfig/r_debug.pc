prefix=D:/a/radare2/radare2/radare2-6.1.8-w64
includedir=${prefix}/include
libdir=${prefix}/lib

Name: r_debug
Description: radare foundation libraries
Version: 6.1.8
Requires: r_util, r_muta, r_reg, r_bin, r_syscall, r_arch, r_anal, r_flag, r_io, r_bp, r_search, r_cons, r_lang, r_egg, r_socket
Requires.private: r_esil
Libs: -L${libdir} -lr_debug 
Libs.private: -lpsapi -lws2_32 -lwininet
Cflags: -I${includedir}/libr
