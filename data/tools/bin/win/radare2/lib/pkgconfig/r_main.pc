prefix=D:/a/radare2/radare2/radare2-6.1.8-w64
includedir=${prefix}/include
libdir=${prefix}/lib

Name: r_main
Description: radare foundation libraries
Version: 6.1.8
Requires: r_core, r_asm, r_syscall
Requires.private: r_config, r_cons, r_util, r_io, r_flag, r_arch, r_esil, r_debug, r_bin, r_lang, r_anal, r_bp, r_egg, r_reg, r_search, r_socket, r_fs, r_magic, r_muta
Libs: -L${libdir} -lr_main 
Libs.private: -lpsapi -lws2_32 -lwininet
Cflags: -I${includedir}/libr
