prefix=D:/a/radare2/radare2/radare2-6.1.8-w64
includedir=${prefix}/include
libdir=${prefix}/lib

Name: r_lang
Description: radare foundation libraries
Version: 6.1.8
Requires: r_util, r_asm, r_muta, r_esil, r_arch, r_cons
Requires.private: r_io, r_socket
Libs: -L${libdir} -lr_lang 
Libs.private: -lpsapi -lws2_32 -lwininet
Cflags: -I${includedir}/libr
