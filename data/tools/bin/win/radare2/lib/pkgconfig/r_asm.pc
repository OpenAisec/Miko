prefix=D:/a/radare2/radare2/radare2-6.1.8-w64
includedir=${prefix}/include
libdir=${prefix}/lib

Name: r_asm
Description: radare foundation libraries
Version: 6.1.8
Requires: r_util, r_syscall, r_reg, r_flag, r_arch, r_socket, r_esil, r_muta
Libs: -L${libdir} -lr_asm 
Libs.private: -lpsapi -lws2_32 -lwininet
Cflags: -I${includedir}/libr
