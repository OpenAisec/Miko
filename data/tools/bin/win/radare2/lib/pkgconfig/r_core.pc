prefix=D:/a/radare2/radare2/radare2-6.1.8-w64
includedir=${prefix}/include
libdir=${prefix}/lib

Name: r_core
Description: radare foundation libraries
Version: 6.1.8
Requires: r_magic, r_anal, r_arch, r_asm, r_bin, r_bp, r_config, r_cons, r_muta, r_debug, r_egg, r_esil, r_flag, r_fs, r_io, r_lang, r_reg, r_search, r_socket, r_syscall, r_util
Libs: -L${libdir} -lr_core 
Libs.private: -lpsapi -lws2_32 -lwininet
Cflags: -I${includedir}/libr
